    {
      "parameters": {
        "resource": "image",
        "operation": "analyze",
        "modelId": {
          "__rl": true,
          "value": "gpt-4o",
          "mode": "list",
          "cachedResultName": "gpt-4o"
        },
        "text": "You are a social media marketing expert for \"Vaidik Greens\" — a premium luxury resort and cottage property located in India. The resort offers: luxury cottages & farmhouses, world-class dining, spa & wellness center, swimming pools & water features, pond with boating, disco & pub, VIP lounges, conference & meeting halls, wedding celebration venues, entertainment & nightlife, medical services, family-friendly amenities, nature-friendly sustainable living, and transport facilities.\n\nAnalyze this image and generate a social media post for Vaidik Greens.\n\nReturn your response in this EXACT JSON format (no markdown, no code blocks):\n{\n  \"title\": \"A short, catchy SEO-friendly title (max 60 chars)\",\n  \"description\": \"An engaging social media caption (150-250 chars) with relevant emojis. Include a call-to-action. Mention Vaidik Greens naturally.\",\n  \"hashtags\": \"#VaidikGreens #LuxuryResort and 5-8 more relevant hashtags\",\n  \"alt_text\": \"A brief, accessible description of the image for SEO (max 125 chars)\"\n}",
        "inputType": "base64",
        "binaryPropertyName": "image",
        "options": {
          "maxTokens": 500
        }
      },
      "type": "@n8n/n8n-nodes-langchain.openAi",
      "typeVersion": 1.8,
      "position": [
        -2640,
        2928
      ],
      "id": "984ef93b-efc6-4d4e-a0d4-eb3b88ec8c60",
      "name": "OpenAI - Generate Content",
      "credentials": {
        "openAiApi": {
          "id": "oeU3bDddqKmVY1Rx",
          "name": "OpenAi account"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const items = $input.all();\nconst returnItems = [];\n\nfor (const item of items) {\n  // Get user-provided values from the form\n  const userTitle = item.json['Title'] || item.json['title'] || '';\n  const userDesc = item.json['Description'] || item.json['description'] || '';\n\n  // Parse AI-generated content\n  let aiContent = {};\n  try {\n    const aiText = item.json.text || item.json.content || item.json.message?.content || '';\n    // Remove possible markdown code block wrappers\n    const cleanJson = aiText.replace(/```json\\n?/g, '').replace(/```\\n?/g, '').trim();\n    aiContent = JSON.parse(cleanJson);\n  } catch (e) {\n    aiContent = {\n      title: 'Experience Luxury at Vaidik Greens',\n      description: '🌿 Discover paradise at Vaidik Greens! Book your luxury escape today. 📞 +91-7518500146',\n      hashtags: '#VaidikGreens #LuxuryResort #NatureRetreat #Cottages #Luxury #Resort #India',\n      alt_text: 'Vaidik Greens luxury resort'\n    };\n  }\n\n  // Use user-provided values if available, otherwise use AI-generated\n  const finalTitle = userTitle.trim() || aiContent.title || 'Vaidik Greens';\n  const finalDesc = userDesc.trim() || aiContent.description || '';\n  const hashtags = aiContent.hashtags || '#VaidikGreens #LuxuryResort';\n  const altText = aiContent.alt_text || finalTitle;\n\n  // Build the full social media caption\n  const fullCaption = `${finalDesc}\\n\\n${hashtags}\\n\\n🌐 https://vaidikgreens.com\\n📞 +91-7518500146`;\n\n  // Clean title for filename\n  const cleanFileName = finalTitle.replace(/[^a-zA-Z0-9_-]/g, '_').substring(0, 50) + '.webp';\n\n  returnItems.push({\n    json: {\n      title: finalTitle,\n      description: finalDesc,\n      fullCaption: fullCaption,\n      hashtags: hashtags,\n      altText: altText,\n      fileName: cleanFileName,\n      wordpress_url: item.json.wordpress_url,\n      facebook_page_id: item.json.facebook_page_id,\n      instagram_user_id: item.json.instagram_user_id,\n      gmb_account_id: item.json.gmb_account_id,\n      gmb_location_id: item.json.gmb_location_id\n    },\n    binary: item.binary\n  });\n}\n\nreturn returnItems;"
      },
