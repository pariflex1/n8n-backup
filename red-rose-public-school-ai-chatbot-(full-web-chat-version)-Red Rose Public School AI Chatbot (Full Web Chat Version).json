    {
      "parameters": {
        "functionCode": "const cheerio = require('cheerio');\nconst html = $json.data || $json.body || '';\nconst $ = cheerio.load(html);\n\nlet text = $('body').text().replace(/\\s+/g, ' ').trim();\ntext = text.substring(0, 18000); // Keep first 18k chars for performance\n\n$global.set('redrose_cache', { content: text, timestamp: new Date().getTime() });\nreturn [{ content: text, question: $json.question }];"
      },
      "name": "Clean & Cache Website Text",
