      "parameters": {
        "functionCode": "const now = new Date().getTime();\nconst cache = $global.get('redrose_cache') || {};\n\n// Cache validity: 6 hours\nconst valid = cache.timestamp && (now - cache.timestamp < 6 * 60 * 60 * 1000);\n\nreturn [{ valid, cache, question: $json.text || $json.message || '' }];"
      },
